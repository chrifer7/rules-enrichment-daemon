APP_NAME=rules-enrichment-daemon
APP_ENV=local
APP_VERSION=0.1.0

LOG_LEVEL=INFO
LOG_ECS_ENABLED=true
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/daemon.log

EXTERNAL_API_BASE_URL=http://localhost:8000
EXTERNAL_API_TIMEOUT_SECONDS=8
EXTERNAL_API_API_KEY=

POLL_INTERVAL_SECONDS=10
POLL_BATCH_SIZE=25
RULE_CACHE_TTL_SECONDS=30
MAX_PROCESSING_ATTEMPTS=3
OUTBOX_PUBLISH_INTERVAL_SECONDS=5

DATABASE_URL=postgresql+psycopg://daemon:daemon@localhost:5433/rules_enrichment_daemon
USE_SQLITE=false
SQLITE_DATABASE_URL=sqlite+pysqlite:///./rules_enrichment_daemon.db

ENRICHMENT_SOURCE_SYSTEM=rules-enrichment-daemon
ENRICHMENT_VERSION=1

OUTBOX_SINK_MODE=log
OUTBOX_WEBHOOK_URL=

ELASTIC_APM_ENABLED=false
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SERVICE_NAME=rules-enrichment-daemon
